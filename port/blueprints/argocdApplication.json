{
  "identifier": "argocdApplication",
  "title": "ArgoCD Application",
  "icon": "Argo",
  "description": "The reconciliation unit that owns a chunk of cluster state from Git. Populated by the port-k8s-exporter watching Application CRs in the argocd namespace.",
  "schema": {
    "properties": {
      "syncStatus": {
        "type": "string",
        "title": "Sync status",
        "enum": ["Synced", "OutOfSync", "Unknown"],
        "enumColors": {
          "Synced": "green",
          "OutOfSync": "orange",
          "Unknown": "lightGray"
        }
      },
      "health": {
        "type": "string",
        "title": "Health",
        "enum": ["Healthy", "Progressing", "Degraded", "Suspended", "Missing", "Unknown"],
        "enumColors": {
          "Healthy": "green",
          "Progressing": "blue",
          "Degraded": "red",
          "Suspended": "lightGray",
          "Missing": "lightGray",
          "Unknown": "lightGray"
        }
      },
      "repoURL": {
        "type": "string",
        "format": "url",
        "title": "Repo URL"
      },
      "targetRevision": {
        "type": "string",
        "title": "Target revision"
      },
      "path": {
        "type": "string",
        "title": "Path"
      },
      "destinationNamespace": {
        "type": "string",
        "title": "Destination namespace"
      },
      "syncWave": {
        "type": "string",
        "title": "Sync wave"
      }
    },
    "required": ["syncStatus", "health"]
  },
  "calculationProperties": {},
  "mirrorProperties": {},
  "relations": {
    "cluster": {
      "title": "Cluster",
      "target": "k8sCluster",
      "required": true,
      "many": false
    }
  }
}
