{
  "identifier": "runningService",
  "title": "Running Service",
  "icon": "Deployment",
  "description": "A live instance of a Service running in a specific cluster. One per (service × cluster). Created by the port-k8s-exporter from the Deployment workload it observes.",
  "schema": {
    "properties": {
      "imageTag": {
        "type": "string",
        "title": "Image tag"
      },
      "replicas": {
        "type": "number",
        "title": "Replicas (desired)"
      },
      "availableReplicas": {
        "type": "number",
        "title": "Available replicas"
      },
      "namespace": {
        "type": "string",
        "title": "Namespace"
      },
      "argocdSyncStatus": {
        "type": "string",
        "title": "ArgoCD sync status",
        "enum": ["Synced", "OutOfSync", "Unknown"],
        "enumColors": {
          "Synced": "green",
          "OutOfSync": "orange",
          "Unknown": "lightGray"
        }
      },
      "argocdHealth": {
        "type": "string",
        "title": "ArgoCD health",
        "enum": ["Healthy", "Progressing", "Degraded", "Suspended", "Missing", "Unknown"],
        "enumColors": {
          "Healthy": "green",
          "Progressing": "blue",
          "Degraded": "red",
          "Suspended": "lightGray",
          "Missing": "lightGray",
          "Unknown": "lightGray"
        }
      },
      "hasHealthz": {
        "type": "boolean",
        "title": "Exposes /healthz"
      },
      "hasReadyz": {
        "type": "boolean",
        "title": "Exposes /readyz"
      },
      "hasServiceMonitor": {
        "type": "boolean",
        "title": "ServiceMonitor present"
      },
      "hasPDB": {
        "type": "boolean",
        "title": "PodDisruptionBudget present"
      },
      "hasDashboard": {
        "type": "boolean",
        "title": "Grafana dashboard present"
      },
      "hasAlerts": {
        "type": "boolean",
        "title": "PrometheusRule present"
      }
    },
    "required": []
  },
  "calculationProperties": {},
  "mirrorProperties": {
    "tier": {
      "path": "service.tier",
      "title": "Tier (from Service)"
    },
    "oncall": {
      "path": "service.oncall",
      "title": "On-call (from Service)"
    }
  },
  "relations": {
    "service": {
      "title": "Service",
      "target": "service",
      "required": true,
      "many": false
    },
    "cluster": {
      "title": "Cluster",
      "target": "k8sCluster",
      "required": true,
      "many": false
    }
  }
}
