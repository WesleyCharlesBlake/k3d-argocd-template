{
  "identifier": "scaffold_service",
  "title": "Scaffold new service",
  "icon": "Microservice",
  "description": "Creates a new Service: opens a PR adding charts/<name>/ (copy of the myapp chart) plus apps/workload/<name>.yaml (ArgoCD Application). Once merged, ArgoCD reconciles the new workload — no manual steps.",
  "trigger": {
    "type": "self-service",
    "operation": "CREATE",
    "userInputs": {
      "properties": {
        "name": {
          "type": "string",
          "title": "Service name",
          "description": "Kebab-case. Becomes the chart directory, ArgoCD Application name, and Kubernetes Service name.",
          "pattern": "^[a-z][a-z0-9-]{1,30}[a-z0-9]$",
          "minLength": 3
        },
        "language": {
          "type": "string",
          "title": "Language",
          "default": "Go",
          "enum": ["Go", "TypeScript", "Python"]
        },
        "tier": {
          "type": "string",
          "title": "Tier",
          "enum": ["1", "2", "3"],
          "default": "2",
          "description": "1 = customer-facing critical, 3 = internal/best-effort"
        },
        "needs_postgres": {
          "type": "boolean",
          "title": "Needs Postgres?",
          "default": false,
          "description": "If true, the scaffold wires the new chart to the existing CloudNativePG cluster credentials secret."
        },
        "oncall": {
          "type": "string",
          "title": "On-call team",
          "default": "platform"
        }
      },
      "required": ["name", "language", "tier"],
      "order": ["name", "language", "tier", "needs_postgres", "oncall"]
    },
    "blueprintIdentifier": "service"
  },
  "invocationMethod": {
    "type": "GITHUB",
    "org": "WesleyCharlesBlake",
    "repo": "chainlink-take-home",
    "workflow": "port-scaffold-service.yml",
    "workflowInputs": {
      "name": "{{ .inputs.name }}",
      "language": "{{ .inputs.language }}",
      "tier": "{{ .inputs.tier }}",
      "needs_postgres": "{{ .inputs.needs_postgres }}",
      "oncall": "{{ .inputs.oncall }}",
      "port_context": {
        "run_id": "{{ .run.id }}",
        "blueprint": "{{ .action.blueprint }}",
        "triggered_by": "{{ .trigger.by.user.email }}"
      }
    },
    "reportWorkflowStatus": true
  },
  "requiredApproval": false
}
